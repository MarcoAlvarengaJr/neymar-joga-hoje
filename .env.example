# =============================================================
#  MODELO de variáveis de ambiente (versionado, SEM segredos).
#  Copie para ".env.local" e preencha com os dados reais do
#  servidor/banco do Johann. O ".env.local" é ignorado pelo git.
# =============================================================

# ---- API que o frontend (votacao.js) vai chamar ----
# Deixe vazio enquanto a votação/comentários usam localStorage.
# Quando a API estiver pronta, coloque a URL base (ex: https://api.neymarjogahoje.com.br)
API_BASE_URL=

# ---- Banco de dados (usado pelo backend, ex: PHP na Locaweb) ----
# Se o banco for o MySQL da própria hospedagem, DB_HOST normalmente é "localhost".
DB_DRIVER=mysql
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# ---- Origem permitida (CORS) ----
# Domínio do site que pode chamar a API.
CORS_ORIGIN=https://neymarjogahoje.com.br
